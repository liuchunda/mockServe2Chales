{
  "name": "mockserver-mcp-charles",
  "version": "1.2.0",
  "description": "MCP Mock Server for React Native with Charles proxy support",
  "main": "dist/server.js",
  "bin": {
    "mockserver-mcp-charles": "./dist/server.js"
  },
  "exports": {
    ".": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mock",
    "server",
    "react-native",
    "charles",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liuchunda/mockServe2Chales.git"
  },
  "homepage": "https://github.com/liuchunda/mockServe2Chales#readme",
  "bugs": {
    "url": "https://github.com/liuchunda/mockServe2Chales/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
